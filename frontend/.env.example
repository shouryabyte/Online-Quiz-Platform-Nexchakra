# Frontend env
#
# Option A (direct to backend):
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
#   (leave API_PROXY_TARGET empty)
#
# Option B (recommended on Vercel): proxy /api/* through the frontend domain
#   so cookies + OAuth callbacks stay first-party:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
#   API_PROXY_TARGET=http://localhost:4000

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_PROXY_TARGET=
