# Required
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/quiz_platform
CLIENT_ORIGIN=http://localhost:3000
AUTH_JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
AUTH_JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=qp_token

# Admin auth (separate from normal users)
ADMIN_COOKIE_NAME=qp_admin_token
ADMIN_JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
ADMIN_JWT_EXPIRES_IN=7d

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional: seed an admin account (used by `npm -C backend run seed:admin`)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_me_please
ADMIN_SEED_NAME=Admin